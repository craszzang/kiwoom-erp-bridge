use_mock: true
mock_mode: catch
account_no: ""

mock:
  mode: catch
  account_no: ""
  user_id: ""

real:
  account_no: ""

screen_no: "0101"
real_screen_no: "0102"

# market = �ڽ���+�ڽ��� ������ / watch_codes = �Ʒ� ��ϸ�
watch_mode: market
watch_codes:
  - "005930"

condition_name: ""
condition_index: 0
max_positions: 3
order_qty: 1
buy_drop_pct: 1.0
sell_rise_pct: 1.5
log_level: INFO

filters:
  min_sell_balance_pct: 50.0
  min_execution_strength: 100.0
  filter_pass_only: false

brm_tr_screen_no: "0104"

brm:
  enabled: false
  paper_only: true
  session_start: "09:00"
  session_end: "11:00"
  entry_cutoff: "10:30"
  martin_trigger_pct: 0.2
  add_limit_pct: 3.0
  stop_loss_pct: 5.0
  tp_pct: 1.5
  min_session_volume: 0
  require_volume_surge: false
  max_symbols: 40
  log_signals: true
